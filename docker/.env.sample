# See https://docs.karakeep.app/configuration for more information
DATA_DIR=/data
MEILI_ADDR=http://127.0.0.1:7700
MEILI_MASTER_KEY=[generate with <openssl rand -base64 36 | tr -dc 'A-Za-z0-9'>]
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=[generate with <openssl rand -base64 36>]

# Database (optional, defaults to SQLite)
# To use PostgreSQL, add docker-compose.postgres.yml as an overlay:
#   docker compose -f docker-compose.yml -f docker-compose.postgres.yml up
#
# The overlay sets DATABASE_DIALECT and DATABASE_URL automatically.
# You only need to set the password (and optionally user/name):
# DATABASE_PASSWORD=changeme
# DATABASE_USER=karakeep
# DATABASE_NAME=karakeep
#
# To connect to an external PostgreSQL (without the overlay):
# DATABASE_DIALECT=postgresql
# DATABASE_URL=postgresql://user:password@host:5432/karakeep
