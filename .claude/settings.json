{
  "permissions": {
    "allow": [
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm --filter * typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm --filter * lint:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm --filter * format:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm --filter * test:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx block-no-verify@1.1.2"
          }
        ]
      }
    ]
  }
}
