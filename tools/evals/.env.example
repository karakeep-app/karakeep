# Required
OPENAI_API_KEY=sk-...

# Optional: custom base URL (for OpenRouter, Azure, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model under evaluation (default: gpt-4.1-mini)
# EVAL_TEXT_MODEL=gpt-4.1-mini

# Model used for LLM-as-judge scoring (default: gpt-4.1-mini)
# EVAL_JUDGE_MODEL=gpt-4.1-mini

# Context length for prompt truncation (default: 8000)
# EVAL_CONTEXT_LENGTH=8000
